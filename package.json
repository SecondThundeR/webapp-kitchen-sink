{
  "name": "webapp-kitchen-sink",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:write": "turbo run lint:write",
    "format": " turbo run format",
    "clean:modules": "bash -lc 'find . -type d -name node_modules -prune -print -exec rm -rf {} \\; && rm -f bun.lock'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.13"
    }
  }
}
