{
  "name": "@webapp-kitchen-sink/bot",
  "version": "1.0.0",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "imports": {
    "#root/*.js": "./src/*.ts",
    "#root/*": "./src/*.ts"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.8.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development node --watch ./src/main.ts",
    "build": "tsdown",
    "start": "NODE_ENV=production node ./dist/main.mjs",
    "typecheck": "tsc",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@grammyjs/auto-chat-action": "0.1.1",
    "@grammyjs/auto-retry": "2.0.2",
    "@grammyjs/hydrate": "1.7.0",
    "@grammyjs/parse-mode": "1.11.1",
    "@grammyjs/runner": "2.0.3",
    "@hono/node-server": "catalog:",
    "@webapp-kitchen-sink/config": "workspace:*",
    "grammy": "1.44.0",
    "hono": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  },
  "packageManager": "pnpm@11.8.0"
}
