{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".tsbuildinfo",
    "types": ["node"],
    "paths": {
      "#root/*": ["./src/*"]
    },
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "dist-types"],
  "references": [{ "path": "../../packages/config" }]
}
