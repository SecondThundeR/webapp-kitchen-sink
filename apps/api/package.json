{
  "name": "@webapp-kitchen-sink/api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "imports": {
    "#root/*": "./src/*"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.2.2"
  },
  "types": "src/exports.ts",
  "exports": {
    ".": {
      "types": "./src/exports.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "start": "NODE_ENV=production tsx src/index.ts",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "2.0.3",
    "@hono/valibot-validator": "0.6.1",
    "@webapp-kitchen-sink/config": "workspace:*",
    "hono": "4.12.22",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsx": "4.22.3"
  },
  "packageManager": "pnpm@11.2.2"
}
