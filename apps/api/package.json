{
  "name": "@webapp-kitchen-sink/api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "imports": {
    "#root/*": "./src/*.ts"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.2.2"
  },
  "types": "./dist-types/exports.d.ts",
  "exports": {
    ".": {
      "types": "./dist-types/exports.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development node --watch --enable-source-maps ./src/index.ts",
    "build": "tsdown",
    "start": "NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/valibot-validator": "0.6.1",
    "@webapp-kitchen-sink/config": "workspace:*",
    "hono": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "^0.22.0"
  },
  "packageManager": "pnpm@11.2.2"
}
