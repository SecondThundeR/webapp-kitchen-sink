{
  "name": "webapp-kitchen-sink",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.3.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:write": "turbo run lint:write",
    "format": "turbo run format",
    "clean:modules": "bash -lc 'find . -type d -name node_modules -prune -print -exec rm -rf {} \\; && rm -f pnpm-lock.yaml'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "turbo": "2.9.15",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.3.0"
}
