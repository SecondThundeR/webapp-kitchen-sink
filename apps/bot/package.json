{
  "name": "@webapp-kitchen-sink/bot",
  "version": "1.0.0",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "imports": {
    "#root/*": "./src/*"
  },
  "engines": {
    "node": ">=26.1.0",
    "pnpm": ">=11.2.2"
  },
  "scripts": {
    "dev": "NODE_ENV=development node --watch ./src/main.ts",
    "start": "NODE_ENV=production node ./src/main.ts",
    "lint": "biome check",
    "lint:write": "biome check --write",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@grammyjs/auto-chat-action": "0.1.1",
    "@grammyjs/auto-retry": "2.0.2",
    "@grammyjs/hydrate": "1.6.0",
    "@grammyjs/parse-mode": "1.11.1",
    "@grammyjs/runner": "2.0.3",
    "@hono/node-server": "2.0.3",
    "grammy": "1.43.0",
    "hono": "4.12.22",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1"
  }
}
